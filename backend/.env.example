# ─── SyncHub Backend Environment Variables ────────────
# Copy this file to .env and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secrets (use strong random strings in production)
JWT_SECRET="change-me-to-a-random-string"
ACCESS_TOKEN_SECRET="change-me-to-a-random-string"
REFRESH_TOKEN_SECRET="change-me-to-a-random-string"

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/auth/google/callback

# Discord OAuth
# Create at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:5001/auth/discord/callback

# Google Gemini AI (free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Frontend origin allowed by CORS and OAuth redirects.
# Use CLIENT_URL for the primary app URL, or CLIENT_URLS for a comma-separated allow-list.
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000

# Server
PORT=5001

# WebRTC SFU media ports.
# In production, set MEDIASOUP_ANNOUNCED_ADDRESS to the public IP/hostname
# clients can reach, and open MEDIASOUP_RTC_MIN_PORT-MEDIASOUP_RTC_MAX_PORT
# for UDP and TCP.
MEDIASOUP_ANNOUNCED_ADDRESS=127.0.0.1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_RTC_MIN_PORT=10000
MEDIASOUP_RTC_MAX_PORT=10100
